# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_PROJECT_ID=your_project_id

# PostgreSQL connection string (Supabase session pooler)
SUPABASE_DB_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# Optional Render-style variable name (used if SUPABASE_DB_URL is empty)
# DATABASE_URL=postgresql://...

# JWT Secret for auth tokens
JWT_SECRET=change-this-to-a-strong-secret

# External inference endpoints (HF Spaces or any compatible service)
NER_API_URL=https://harsh710000-ctas-ner-api.hf.space/predict
CLF_API_URL=https://harsh710000-biobert-classifier-api.hf.space/predict

# Optional: comma-separated allowed origins for CORS
# Example: CORS_ORIGINS=https://your-frontend.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=*
